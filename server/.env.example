PORT=4000
DATABASE_URL=postgres://monitorpro:changeme@localhost:5432/monitorpro
JWT_SECRET=change-this-to-a-long-random-string
COOKIE_NAME=monitorpro_session
FRONTEND_ORIGIN=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
