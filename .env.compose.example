# Used by docker-compose.yml. Copy to .env and fill in real values before deploying
# (Coolify: set these as the app's environment variables instead of a file).

DB_PASSWORD=changeme
JWT_SECRET=change-this-to-a-long-random-string

# Public URL of the frontend (e.g. https://monitor.example.com). Must match
# the origin the browser actually uses, since cookies are same-site scoped.
FRONTEND_ORIGIN=http://localhost:3000

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@monitorpro.io

# Seeds a single owner account on first boot only (ignored once any user exists).
ADMIN_EMAIL=
ADMIN_PASSWORD=
